{
  "type": "module",
  "name": "healthapp",
  "version": "1.0.0",
  "description": "exercise for typescript curse",
  "main": "none",
  "scripts": {
    "tsc": "tsc --noEmit",
    "calculateBmi": "tsc && node --no-warnings --loader ts-node/esm bmiCalculator.ts ",
    "calculateExercises": "tsc && node --no-warnings --loader ts-node/esm exerciseCalculator.ts ",
    "start": "tsc && node --no-warnings --loader ts-node/esm index.ts",
    "dev": "concurrently \"tsc && node --no-warnings --loader ts-node/esm --watch index.ts\"",
    "lint": "eslint ."
  },
  "keywords": [
    "typescript"
  ],
  "author": "GRR",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
